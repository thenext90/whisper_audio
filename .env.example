# AudioToText Web — Configuración de entorno
# Copia este archivo a .env y ajusta los valores

# Puerto de la aplicación (por defecto 5000)
PORT=5000

# Clave secreta Flask (¡cámbiala en producción!)
SECRET_KEY=change-me-super-secret-key

# Debug mode (false en producción, true en desarrollo)
FLASK_DEBUG=false
